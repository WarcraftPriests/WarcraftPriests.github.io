{
  "name": "warcraftpriests.github.io",
  "version": "1.0.0",
  "type": "module",
  "description": "This is the World of Warcraft Priest Sim Chart website.",
  "main": "index.js",
  "scripts": {
    "copy-highcharts": "node scripts/copyHighcharts.js",
    "build:tailwind": "tailwindcss -c tailwind.config.js -i ./css/tailwind.input.css -o ./css/tailwind.generated.css --minify",
    "watch:tailwind": "tailwindcss -c tailwind.config.js -i ./css/tailwind.input.css -o ./css/tailwind.generated.css --watch",
    "prepare": "npm run copy-highcharts && npm run build:tailwind",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "start": "npm run build:tailwind && npx http-server -p 8080"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "highcharts": "^12.5.0"
  },
  "devDependencies": {
    "eslint": "^10.0.2",
    "jest": "^29.7.0",
    "tailwindcss": "^3.4.17"
  }
}
